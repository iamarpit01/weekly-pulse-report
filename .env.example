# Groq API Key for the LLM Summarizer
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Docs Configuration (Phase 5)
# The ID of the Google Doc to append the weekly pulse report to
TARGET_DOC_ID=your_google_doc_id_here

# Gmail Configuration (Phase 5)
# Comma-separated list of emails to send the teaser to
STAKEHOLDER_EMAILS=product@example.com,engineering@example.com

# MCP Server Configuration
# Points the agent to the custom Python-based Google Workspace MCP server
MCP_SERVER_COMMAND=python3
MCP_SERVER_ARGS="-m src.mcp_server.server"

# Google Authentication
# Provide the absolute path to your GCP service account JSON key
# Or leave blank to use the browser-based OAuth2 login (credentials.json)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service_account.json
